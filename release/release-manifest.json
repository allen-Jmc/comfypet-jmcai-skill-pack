{
  "schema_version": 1,
  "repo_role": "skill-pack",
  "repo_name": "comfypet-jmcai-skill-pack",
  "version_probe": {
    "type": "regex_extract",
    "path": "skills/comfypet-jmcai-skill/scripts/jmcai_skill.py",
    "pattern": "^VERSION = \"([^\"]+)\"$"
  },
  "git": {
    "default_branch": "main",
    "release_commit_template": "release: skill-pack v{version}",
    "tag_template": "v{version}"
  },
  "version_operations": [
    {
      "phase": "prepare",
      "type": "regex_replace",
      "path": "skills/comfypet-jmcai-skill/scripts/jmcai_skill.py",
      "pattern": "^VERSION = \"[^\"]+\"$",
      "replacement": "VERSION = \"{version}\""
    },
    {
      "phase": "prepare",
      "type": "regex_replace",
      "path": "README.md",
      "pattern": "dist/comfypet-jmcai-skill-v\\d+\\.\\d+\\.\\d+\\.zip",
      "replacement": "dist/comfypet-jmcai-skill-v{version}.zip"
    },
    {
      "phase": "prepare",
      "type": "regex_replace",
      "path": "docs/openai-codex-distribution.md",
      "pattern": "dist/comfypet-jmcai-skill-v\\d+\\.\\d+\\.\\d+\\.zip",
      "replacement": "dist/comfypet-jmcai-skill-v{version}.zip"
    },
    {
      "phase": "prepare",
      "type": "regex_replace",
      "path": "docs/platform-distribution.md",
      "pattern": "dist/comfypet-jmcai-skill-v\\d+\\.\\d+\\.\\d+\\.zip",
      "replacement": "dist/comfypet-jmcai-skill-v{version}.zip"
    },
    {
      "phase": "prepare",
      "type": "regex_replace",
      "path": "docs/install-guide.md",
      "pattern": "jmcai-skill \\d+\\.\\d+\\.\\d+",
      "replacement": "jmcai-skill {version}"
    },
    {
      "phase": "prepare",
      "type": "regex_replace",
      "path": "docs/openclaw-clawhub-distribution.md",
      "pattern": "- `version`: `\\d+\\.\\d+\\.\\d+`",
      "replacement": "- `version`: `{version}`"
    },
    {
      "phase": "prepare",
      "type": "regex_replace",
      "path": "docs/openclaw-clawhub-distribution.md",
      "pattern": "--version \\d+\\.\\d+\\.\\d+",
      "replacement": "--version {version}"
    },
    {
      "phase": "prepare",
      "type": "regex_replace",
      "path": "docs/openclaw-clawhub-distribution.md",
      "pattern": "- `changelog`: `[^`]+`",
      "replacement": "- `changelog`: `Release {version}`"
    },
    {
      "phase": "prepare",
      "type": "regex_replace",
      "path": "docs/openclaw-clawhub-distribution.md",
      "pattern": "--changelog \"[^\"]+\"",
      "replacement": "--changelog \"Release {version}\""
    },
    {
      "phase": "prepare",
      "type": "regex_replace",
      "path": "release/build-distribution.ps1",
      "pattern": "\\[string\\]\\$Version = '[^']+'",
      "replacement": "[string]$Version = '{version}'"
    },
    {
      "phase": "prepare",
      "type": "regex_replace",
      "path": "release/build-distribution.sh",
      "pattern": "version=\"\\$\\{1:-[^}]+\\}\"",
      "replacement": "version=\"${1:-{version}}\""
    },
    {
      "phase": "prepare",
      "type": "regex_replace",
      "path": "release/clawhub-publish.ps1",
      "pattern": "\\[string\\]\\$Version = '[^']+'",
      "replacement": "[string]$Version = '{version}'"
    },
    {
      "phase": "prepare",
      "type": "regex_replace",
      "path": "release/clawhub-publish.ps1",
      "pattern": "\\[string\\]\\$Changelog = '[^']+'",
      "replacement": "[string]$Changelog = 'Release {version}'"
    },
    {
      "phase": "prepare",
      "type": "regex_replace",
      "path": "release/clawhub-publish.sh",
      "pattern": "version=\"\\$\\{1:-[^}]+\\}\"",
      "replacement": "version=\"${1:-{version}}\""
    },
    {
      "phase": "prepare",
      "type": "regex_replace",
      "path": "release/clawhub-publish.sh",
      "pattern": "changelog=\"\\$\\{3:-[^}]+\\}\"",
      "replacement": "changelog=\"${3:-Release {version}}\""
    },
    {
      "phase": "publish",
      "type": "regex_replace",
      "path": "README.md",
      "pattern": "comfypet-jmcai-skill@\\d+\\.\\d+\\.\\d+",
      "replacement": "comfypet-jmcai-skill@{version}"
    },
    {
      "phase": "publish",
      "type": "regex_replace",
      "path": "docs/platform-distribution.md",
      "pattern": "comfypet-jmcai-skill@\\d+\\.\\d+\\.\\d+",
      "replacement": "comfypet-jmcai-skill@{version}"
    },
    {
      "phase": "publish",
      "type": "regex_replace",
      "path": "docs/openclaw-clawhub-distribution.md",
      "pattern": "comfypet-jmcai-skill@\\d+\\.\\d+\\.\\d+",
      "replacement": "comfypet-jmcai-skill@{version}"
    },
    {
      "phase": "publish",
      "type": "regex_replace",
      "path": "docs/release-readiness.md",
      "pattern": "comfypet-jmcai-skill@\\d+\\.\\d+\\.\\d+",
      "replacement": "comfypet-jmcai-skill@{version}"
    }
  ],
  "changelog": {
    "phase": "prepare",
    "path": "CHANGELOG.md",
    "unreleased_heading": "## Unreleased",
    "default_entry_template": "- Release {version}."
  },
  "prepare_commands": [
    {
      "name": "python-compile",
      "command": [
        "python",
        "-m",
        "py_compile",
        "skills/comfypet-jmcai-skill/scripts/jmcai_skill.py"
      ]
    },
    {
      "name": "build-distribution",
      "command": [
        "pwsh",
        "-File",
        ".\\release\\build-distribution.ps1",
        "-Version",
        "{version}"
      ]
    }
  ],
  "artifacts": [
    {
      "label": "skill payload directory",
      "path": "dist/comfypet-jmcai-skill"
    },
    {
      "label": "release zip",
      "path": "dist/comfypet-jmcai-skill-v{version}.zip"
    },
    {
      "label": "release checksums",
      "path": "dist/checksums.txt"
    }
  ],
  "publish_checklist": [
    "Verify the generated dist payload and checksum before external publish.",
    "Confirm the GitHub release title and ClawHub changelog are correct."
  ],
  "publish_commands": [
    {
      "name": "github-release",
      "requires_auth": "gh",
      "command": [
        "gh",
        "release",
        "create",
        "{tag}",
        "dist/comfypet-jmcai-skill-v{version}.zip",
        "dist/checksums.txt",
        "--repo",
        "allen-Jmc/comfypet-jmcai-skill-pack",
        "--title",
        "comfypet-jmcai-skill v{version}",
        "--notes-file",
        "{gh_notes_file}"
      ]
    },
    {
      "name": "clawhub-publish",
      "requires_auth": "clawhub",
      "command": [
        "clawhub",
        "publish",
        ".\\skills\\comfypet-jmcai-skill",
        "--slug",
        "comfypet-jmcai-skill",
        "--name",
        "JMCAI Comfypet",
        "--version",
        "{version}",
        "--tags",
        "latest,comfyui,image,video,jmcai",
        "--changelog",
        "{clawhub_changelog}"
      ]
    }
  ]
}
